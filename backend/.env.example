# 🔧 CONFIGURAÇÃO DO BACKEND

# Servidor
PORT=3001
NODE_ENV=development

# Banco de dados
DB_PATH=./data/cabeleireiro.db

# CORS
CORS_ORIGIN=http://localhost:5174

# Autenticação
# Gere um segredo único por ambiente (nunca reutilize este valor do exemplo e nunca commite o segredo real no Git).
# Exemplo para gerar um valor forte: node -e "const crypto=require('crypto'); console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=troque_este_secret_em_producao
# Senha inicial do usuário administrador mestre (login: Rodrigo Campos)
AUTH_ADMIN_PASSWORD=100769
AUTH_TOKEN_TTL_HOURS=12

# API WhatsApp (opcional)
WHATSAPP_API_KEY=sua_chave_aqui
WHATSAPP_INSTANCE_ID=sua_instancia_aqui

# Comissões padrão
DEFAULT_COMMISSION_PERCENTAGE=35
